# KiriPilot Support Chat — настройки сервера
# Скопируйте этот файл в .env и заполните реальными значениями

# Порт сервера
PORT=3000

# SMTP для отправки OTP-писем
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# Секретный токен для входа в панель /kiri-admin
# Используйте длинный случайный пароль!
ADMIN_TOKEN=super-secret-admin-token-change-me
